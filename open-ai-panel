#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
URL="${AI_PANEL_URL:-http://127.0.0.1:8765}"
LOG_DIR="${SCRIPT_DIR}/logs"
LOG_FILE="${LOG_DIR}/server.log"

mkdir -p "${LOG_DIR}"
cd "${SCRIPT_DIR}"

is_up() {
  curl -fsS "${URL}/api/health" >/dev/null 2>&1
}

if ! is_up; then
  echo "AI Panel 서버를 시작합니다..."
  nohup "${SCRIPT_DIR}/ai-panel" serve --no-open >"${LOG_FILE}" 2>&1 &
  for _ in {1..30}; do
    if is_up; then
      break
    fi
    sleep 0.5
  done
fi

if is_up; then
  echo "AI Panel을 엽니다: ${URL}"
  if ! open "${URL}" >/dev/null 2>&1; then
    echo "브라우저에서 직접 열어주세요: ${URL}"
  fi
else
  echo "AI Panel 서버 시작에 실패했습니다."
  echo "로그: ${LOG_FILE}"
  tail -n 40 "${LOG_FILE}" 2>/dev/null || true
  exit 1
fi
