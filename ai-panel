#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PYTHONPATH="${SCRIPT_DIR}/src${PYTHONPATH:+:${PYTHONPATH}}"

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3를 찾을 수 없습니다. Python 3를 설치한 뒤 다시 실행해주세요." >&2
  exit 1
fi

if [ "$#" -eq 0 ]; then
  exec "${SCRIPT_DIR}/open-ai-panel"
fi

exec python3 -m ai_panel "$@"
